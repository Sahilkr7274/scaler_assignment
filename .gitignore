# ── Dependencies ──────────────────────────────────────────────────────────────
node_modules/
.pnp
.pnp.js

# ── Environment variables (never commit secrets) ───────────────────────────────
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# ── Next.js ───────────────────────────────────────────────────────────────────
.next/
out/

# ── Build outputs ─────────────────────────────────────────────────────────────
dist/
build/

# ── Prisma ────────────────────────────────────────────────────────────────────
# Keep schema.prisma and seed.js — ignore generated client (regenerated via prisma generate)
backend/node_modules/

# ── Logs ──────────────────────────────────────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ── File uploads (user-generated content, not source code) ────────────────────
backend/uploads/*
!backend/uploads/.gitkeep

# ── Netlify ───────────────────────────────────────────────────────────────────
.netlify/
frontend/.netlify/

# ── OS files ──────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ── Editor / IDE ──────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo

# ── TypeScript build info ─────────────────────────────────────────────────────
*.tsbuildinfo
frontend/tsconfig.tsbuildinfo
